{
  "name": "agenthub",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "dev:with-local-ca": "NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "docs:db-schema": "bun run scripts/generate-db-schema-docs.ts",
    "docs:db-schema:check": "bun run scripts/generate-db-schema-docs.ts --check",
    "docs:openapi": "bun run scripts/generate-openapi-docs.ts",
    "docs:openapi:check": "bun run scripts/generate-openapi-docs.ts --check",
    "dev:dummy-agent-card": "bun run scripts/serve-dummy-agent-card.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@elysiajs/openapi": "latest",
    "drizzle-orm": "latest",
    "elysia": "latest",
    "pg": "latest",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/pg": "latest",
    "bun-types": "latest",
    "drizzle-kit": "latest",
    "typescript": "latest"
  },
  "module": "src/index.ts"
}
